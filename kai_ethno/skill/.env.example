# KAI-Ethno Configuration
# Copiar este archivo a .env y completar con tus valores

# APIs de búsqueda (opcional - mejora resultados pero no requerido)
SEMANTIC_SCHOLAR_API_KEY=
ARXIV_EMAIL=
CROSSREF_EMAIL=
PUBMED_API_KEY=

# Base de datos de grafo (opcional)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Configuración general
LOG_LEVEL=INFO
OUTPUT_DIR=./output
MAX_WORKERS=4
CACHE_DIR=./cache

# APIs de IA (opcional - mejora calidad de análisis)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Configuración de ética
STRICT_ETHICS_MODE=false
AUTO_ANONYMIZE_PII=true
